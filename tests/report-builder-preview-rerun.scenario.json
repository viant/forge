{
  "baseUrl": "http://127.0.0.1:5175",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "steps": [
    {
      "type": "goto",
      "url": "/report-builder-preview.html"
    },
    {
      "type": "waitForDomContains",
      "text": "Semantic Report Builder Preview",
      "timeoutMs": 60000
    },
    {
      "type": "clearLocalStorage",
      "keys": [
        "reportBuilder.state.demoReportBuilder.demoReportBuilderWindow",
        "reportBuilder.state.demoReportBuilder",
        "reportBuilder.chartPresets.demoReportBuilder"
      ]
    },
    {
      "type": "reload"
    },
    {
      "type": "waitForDomContains",
      "text": "Semantic Report Builder Preview",
      "timeoutMs": 60000
    },
    {
      "type": "waitForDomContains",
      "text": "Semantic binding: Ad Delivery • Entity: Line Delivery",
      "timeoutMs": 60000
    },
    {
      "type": "waitForDomContains",
      "text": "Table results",
      "timeoutMs": 60000
    },
    {
      "type": "waitForDomContains",
      "text": "CHART NOT CONFIGURED",
      "timeoutMs": 60000
    },
    {
      "type": "eval",
      "expression": "window.__REPORT_BUILDER_PREVIEW__ && window.__REPORT_BUILDER_PREVIEW__.resetCounters && window.__REPORT_BUILDER_PREVIEW__.resetCounters();"
    },
    {
      "type": "clickSelector",
      "selector": ".forge-report-builder__run-button"
    },
    {
      "type": "waitForEval",
      "expression": "Boolean(window.__REPORT_BUILDER_PREVIEW__ && window.__REPORT_BUILDER_PREVIEW__.fetchCollectionCount >= 1)",
      "timeoutMs": 60000
    },
    {
      "type": "waitForDomContains",
      "text": "Avails by Date",
      "timeoutMs": 60000
    },
    {
      "type": "waitForDomContains",
      "text": "Chart-first view for the active scope using the full query result set.",
      "timeoutMs": 60000
    },
    {
      "type": "assertDomContains",
      "text": "Edit Chart"
    },
    {
      "type": "assertDomNotContains",
      "text": "Failed to render dashboard block"
    },
    {
      "type": "screenshot",
      "file": "report-builder-preview-rerun-proof.png"
    }
  ]
}
